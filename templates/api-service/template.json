{
  "name": "api-service",
  "description": "AI agent docs for backend API services (REST or GraphQL)",
  "variables": {
    "projectName": {
      "prompt": "What is your project name?",
      "default": "my-api"
    },
    "apiStyle": {
      "prompt": "What API style do you use? (REST/GraphQL)",
      "default": "REST"
    }
  },
  "ignore": ["template.json"],
  "symlinks": {
    "CLAUDE.md": "AGENTS.md",
    ".cursorrules": "AGENTS.md",
    ".windsurfrules": "AGENTS.md",
    ".clinerules": "AGENTS.md",
    "GEMINI.md": "AGENTS.md",
    ".github/copilot-instructions.md": "../AGENTS.md"
  }
}
