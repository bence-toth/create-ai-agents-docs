{
  "name": "design-system",
  "description": "AI agent docs for component libraries and design systems",
  "variables": {
    "projectName": {
      "prompt": "What is your project name?",
      "default": "my-design-system"
    },
    "framework": {
      "prompt": "Which framework do you use? (React/Vue/Web Components/Svelte)",
      "default": "React"
    }
  },
  "ignore": ["template.json"],
  "symlinks": {
    "CLAUDE.md": "AGENTS.md",
    ".cursorrules": "AGENTS.md",
    ".windsurfrules": "AGENTS.md",
    ".clinerules": "AGENTS.md",
    "GEMINI.md": "AGENTS.md",
    ".github/copilot-instructions.md": "../AGENTS.md"
  }
}
